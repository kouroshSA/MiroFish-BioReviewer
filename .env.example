# ===== LLM API Configuration =====
# Supports any OpenAI SDK-compatible LLM API
# See README for provider-specific examples (Claude, OpenAI, Ollama, etc.)

LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# --- Claude via LiteLLM proxy (recommended for biological mode) ---
# SECURITY: litellm versions 1.82.7 and 1.82.8 were compromised (supply chain attack, March 2026).
# Only install the pinned safe version: pip install litellm==1.82.6
# See SECURITY.md for details.
# 1. pip install litellm==1.82.6
# 2. export ANTHROPIC_API_KEY=sk-ant-...
# 3. litellm --model claude-haiku-4-5-20251001 --port 8000
# Then uncomment:
# LLM_API_KEY=sk-1234
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL_NAME=claude-haiku-4-5-20251001

# --- Ollama (local, free) ---
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL_NAME=qwen2.5:7b

# ===== ZEP Memory Graph Configuration =====
# Sign up (free tier available): https://app.getzep.com/
# Navigate to Project → API Keys → Generate key
ZEP_API_KEY=your_zep_api_key_here

# ===== Agent Soul / Simulation Mode =====
# Options: social (default), biological, custom, grant_review
SIMULATION_MODE=biological
# Grant pre-proposal review mode (new in BioReviewer)
# SIMULATION_MODE=grant_review
# Path to custom agent-soul file (only used when SIMULATION_MODE=custom)
# AGENT_SOUL_PATH=./agent-soul.md

# === Reviewer Panel (grant_review mode only) ===
REVIEWER_PANEL_ENABLED=true
REVIEWER_MECHANIST_TEMPERATURE=0.3
REVIEWER_VISIONARY_TEMPERATURE=0.7
REVIEWER_REALIST_TEMPERATURE=0.4
REVIEWER_MAX_TOKENS=800

# ===== Simulation Settings =====
OASIS_DEFAULT_MAX_ROUNDS=90
MAX_CONCURRENT_LLM_REQUESTS=2

# ===== Discussion & Big Picture Section =====
# Uses a stronger model for academic-quality writing in the Discussion section.
# The LiteLLM proxy routes to the correct model based on the model name.
# Default: claude-sonnet-4-20250514 (good balance of quality and cost)
# Premium: claude-opus-4-6-20250610 (highest quality, most expensive)
# DISCUSSION_LLM_MODEL_NAME=claude-sonnet-4-20250514
